[
  {
    "name": "get_recent_gym_visits",
    "description": "指定期間の直近ジム実施履歴を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "days": {
          "type": "integer",
          "description": "何日前まで取得するか（1-365）"
        },
        "limit": {
          "type": "integer",
          "description": "取得件数上限（1-100）"
        }
      },
      "required": ["userId"]
    }
  },
  {
    "name": "get_training_history",
    "description": "特定トレーニングメニューの過去実施履歴を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "trainingMenuItemId": {
          "type": "string",
          "description": "対象トレーニングメニューID"
        },
        "limit": {
          "type": "integer",
          "description": "取得件数上限（1-100）"
        }
      },
      "required": ["userId", "trainingMenuItemId"]
    }
  },
  {
    "name": "get_daily_records",
    "description": "日付範囲のDaily記録を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "from": {
          "type": "string",
          "description": "開始日（YYYY-MM-DD）"
        },
        "to": {
          "type": "string",
          "description": "終了日（YYYY-MM-DD）"
        }
      },
      "required": ["userId"]
    }
  },
  {
    "name": "get_daily_record",
    "description": "指定日のDaily記録を取得する",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "date": {
          "type": "string",
          "description": "対象日（YYYY-MM-DD）"
        }
      },
      "required": ["userId", "date"]
    }
  },
  {
    "name": "save_daily_diary",
    "description": "Dailyの日記(diary)を保存する。既存日記がある場合はmode指定で追記または上書きする。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "内部利用。Runtime がJWT subを設定する。"
        },
        "diary": {
          "type": "string",
          "description": "保存する日記本文"
        },
        "date": {
          "type": "string",
          "description": "対象日（YYYY-MM-DD）。未指定時はtimeZoneId基準の本日。"
        },
        "timeZoneId": {
          "type": "string",
          "description": "IANAタイムゾーンID。date未指定時の本日判定に使う。"
        },
        "mode": {
          "type": "string",
          "description": "既存日記がある場合の保存モード。append または overwrite。"
        }
      },
      "required": ["userId", "diary"]
    }
  },
  {
