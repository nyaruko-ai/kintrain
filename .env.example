# Copy this file to `.env.local` and fill your own values.
# `.env.local` is ignored by git.

# AWS CLI profile name (recommended). Leave empty if you use env vars or SSO default profile.
AWS_PROFILE=your-aws-profile

# AWS region used by Amplify Gen2 / CDK / S3 deploy
AWS_REGION=ap-northeast-1

# Amplify App ID for branch outputs sync (required for local npm run dev against deployed backend)
AWS_APP_ID=your-amplify-app-id

# Amplify branch to sync outputs from (dev/main etc)
AMPLIFY_BRANCH=dev

# Amplify sandbox identifier (example: yourname, dev, stg)
AMPLIFY_IDENTIFIER=dev

# Frontend hosting bucket name
FRONTEND_S3_BUCKET=your-frontend-bucket-name
